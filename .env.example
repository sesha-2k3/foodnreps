# ─────────────────────────────────────────────────────────────────────────────
# Food 'n' Reps — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is committed as the canonical reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Use @localhost when running `make dev` (backend runs outside Docker).
# The docker-compose.yml backend service overrides this with @db automatically.
DATABASE_URL=postgresql+asyncpg://food_n_reps:food_n_reps@localhost:5432/food_n_reps_db

# Separate test database — created by the integration test suite in Sprint 2.
TEST_DATABASE_URL=postgresql+asyncpg://food_n_reps:food_n_reps@localhost:5432/food_n_reps_test

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit a real secret. The app will refuse to start in production with
# the placeholder value below.
JWT_SECRET=change-me-in-production-use-a-256-bit-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format).
# Add your production domain here when deploying.
ALLOWED_ORIGINS=["http://localhost:5173"]

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development
